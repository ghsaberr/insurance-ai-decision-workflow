# ── LLM ─────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Alternative: local Ollama
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama2:7b

# LLM_PROVIDER=none  ← deterministic_only mode, no LLM

# ── Retrieval (from insurance-nlp-aws pipeline) ───────────────────────
FAISS_INDEX_PATH=data/insurance_faiss.index
FAISS_METADATA_PATH=data/insurance_metadata.json
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Severity model (from claims-severity-prediction) ─────────────────
# SEVERITY_MODEL_PATH=../claims-severity-prediction/claims_severity_model

# ── Storage ──────────────────────────────────────────────────────────
DB_PATH=data/workflow.db

# ── Security ─────────────────────────────────────────────────────────
# Required in production. All endpoints check X-API-Key header.
# If unset, the API runs in open-access mode (development only).
API_KEY=change-me-in-production

# PII hashing salt — MUST be changed from the default before going to production.
# Store this in a secrets manager, not in .env files checked into source control.
PII_HASH_SALT=change-me-to-a-random-secret
