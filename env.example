# Copy this file to .env and fill in values.
# Never commit .env to source control.

# LLM provider: anthropic | ollama | none
LLM_PROVIDER=anthropic

# Anthropic (primary)
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama (alternative)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2:7b

# Retrieval — paths to insurance-nlp-aws pipeline output
FAISS_INDEX_PATH=data/insurance_faiss.index
FAISS_METADATA_PATH=data/insurance_metadata.json

# Severity model — leave blank to use rule-based mode (no GPU needed)
SEVERITY_MODEL_PATH=

# Storage
DB_PATH=data/workflow.db
